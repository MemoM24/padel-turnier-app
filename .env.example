# ─── Padel Turnier App – Backend Environment Variables ────────────────────────
# Copy this file to .env for local development.
# On Railway: set these as Environment Variables in the Railway dashboard.

# ── Pflichtfelder (REQUIRED) ──────────────────────────────────────────────────

# MySQL-Datenbankverbindung (z.B. Railway MySQL Plugin oder PlanetScale)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@host:3306/padel_turnier

# JWT-Secret für Session-Cookies (mindestens 32 zufällige Zeichen)
# Generieren: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── Optionale Felder (OPTIONAL) ───────────────────────────────────────────────

# App-ID (wird von der Manus-Plattform gesetzt, für OAuth-Flows benötigt)
VITE_APP_ID=

# OAuth-Server-URL (nur wenn Manus OAuth genutzt wird)
OAUTH_SERVER_URL=

# Owner-OpenID (Admin-Benutzer-ID für Manus OAuth)
OWNER_OPEN_ID=

# Manus Forge API (für LLM/AI-Features – wird von der Plattform injiziert)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Node-Umgebung (wird automatisch von Railway auf "production" gesetzt)
NODE_ENV=production

# Port (wird automatisch von Railway gesetzt – nicht manuell setzen)
# PORT=3000
